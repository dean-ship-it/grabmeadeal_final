rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deals — public read, admin write only
    match /deals/{dealId} {
      allow read: if true;
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admins
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Users — own data only, recursive match so all subcollections
    // (shoppingList_*, pantryList, todoList, wants, etc.) are covered.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Puzzle progress
    match /puzzle_progress/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Notifications
    match /notifications/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;

      match /items/{itemId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // Store closings — public read
    match /store_closings/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
